# ==================== 环境模式 ====================
# development(开发) / production(生产)
NODE_ENV=development

# ==================== 测试模式 ====================
# DRY RUN 模式：true=只打印日志不执行操作，false=真实执行
#  测试时必保持为 true, 确认无误后再改为 false
DRY_RUN=false

# TEST MODE 测试模式：true=测试模式(选中复选框/模拟输入)，false=生产模式(真实修改)
# 测试模式下：Bid/Block=选中复选框，Budget=删除后输入相同值
TEST_MODE=true

# ==================== 开发环境配置 ====================
DEV_LOGIN_URL="https://ads.pushnami.com/signin"
DEV_USERNAME="jerryli@eflow-media.com"
DEV_PASSWORD="Ntpop132465#"
DEV_CHROME_PATH="C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe"
DEV_HEADLESS="false"
DEV_WINDOW_SIZE="1280,800"

# ==================== 生产环境配置 ====================
PROD_LOGIN_URL="https://ads.pushnami.com/signin"
PROD_USERNAME="jerryli@eflow-media.com"
PROD_PASSWORD="Ntpop132465#"
PROD_CHROME_PATH="/usr/bin/google-chrome"
PROD_HEADLESS="true"
PROD_WINDOW_SIZE="1920,1080"

# ==================== Domain API 配置 ====================
# 后台管理系统的 API 地址，用于记录操作日志和读取配置
# API_BASE_URL="https://efbox.work/api"
API_BASE_URL="http://localhost:8001"
API_TIMEOUT=10000

# ==================== 任务开关 ====================
# Bid 调整任务开关
TASK_BID_ADJUST=true
# Block 任务开关
TASK_BLOCK=true
# Budget 放量任务开关
TASK_BUDGET_BOOST=true

# ==================== Bid 调整规则配置 ====================
# 触发频率（分钟）：每3小时 = 180分钟
BID_ADJUST_INTERVAL=180
# 冷却时间（分钟）：同一Source 100分钟内只调整一次
BID_ADJUST_COOLDOWN=100

# ==================== Block 规则配置 ====================
# CPA 阈值：CPA >= 此值时触发 Block
BLOCK_THRESHOLD=15
# 触发频率（分钟）：每24小时 = 1440分钟
BLOCK_INTERVAL=1440
# 冷却时间（分钟）：同一Source 24小时内只Block一次 = 1440分钟
BLOCK_COOLDOWN=1440

# ==================== Budget 放量规则配置 ====================
# 放量条件：Total Spend >= Daily Spend Limit × 此值
BUDGET_BOOST_SPEND_THRESHOLD=0.5
# 触发频率（分钟）：每24小时 = 1440分钟
BUDGET_BOOST_INTERVAL=1440
# 冷却时间（分钟）：同一Campaign 24小时内只调整一次 = 1440分钟
BUDGET_BOOST_COOLDOWN=1440
# 放量倍数：Daily Spend Limit = 当前值 × 此值
BUDGET_BOOST_MULTIPLIER=2
